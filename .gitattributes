# Set default behavior to automatically normalize line endings
* text=auto

# Force LF line endings for text files
*.js text eol=lf
*.jsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.css text eol=lf
*.mjs text eol=lf
*.config.js text eol=lf
*.config.mjs text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary

